{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS.Builder",
    "buildCommand": "cd backend/inventarios && mvn clean package -DskipTests",
    "installCommand": "cd backend/inventarios && mvn dependency:go-offline"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "cd backend/inventarios && java -jar target/*.jar"
  }
}